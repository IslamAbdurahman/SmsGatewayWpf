<Window x:Class="SmsGatewayApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SmsGatewayApp.ViewModels"
        xmlns:viewModels="clr-namespace:SmsGatewayApp.ViewModels"
        xmlns:views="clr-namespace:SmsGatewayApp.Views"
        xmlns:helpers="clr-namespace:SmsGatewayApp.Helpers"
        mc:Ignorable="d"
        Title="SMS Gateway Pro" Height="800" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}">

    <Window.Resources>
    </Window.Resources>

    <!-- Keyboard Shortcuts -->
    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NavigateCommand}" CommandParameter="Import"/>
        <KeyBinding Key="I" Modifiers="Ctrl" Command="{Binding ImportExcelCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveTemplateCommand}"/>
        <KeyBinding Key="F5"                 Command="{Binding RefreshPortsCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SecondaryBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="SMS GATEWAY" Foreground="White" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="Professional Edition" Foreground="{StaticResource TextDimBrush}" FontSize="12"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,20">
                        <RadioButton Style="{StaticResource SidebarButton}" IsChecked="True" 
                                     Command="{Binding NavigateCommand}" CommandParameter="Dashboard">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource SidebarButton}" 
                                     Command="{Binding NavigateCommand}" CommandParameter="Sending">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE715;" FontFamily="Segoe MDL2 Assets" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                <TextBlock Text="SMS Yuborish" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource SidebarButton}" 
                                     Command="{Binding NavigateCommand}" CommandParameter="Contacts">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE779;" FontFamily="Segoe MDL2 Assets" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Kontaktlar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource SidebarButton}" 
                                     Command="{Binding NavigateCommand}" CommandParameter="Templates">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Shablonlar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource SidebarButton}" 
                                     Command="{Binding NavigateCommand}" CommandParameter="Blacklist">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8D8;" FontFamily="Segoe MDL2 Assets" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Qora Ro'yxat" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource SidebarButton}" 
                                     Command="{Binding NavigateCommand}" CommandParameter="Backup">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Zaxira" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource SidebarButton}" 
                                     Command="{Binding NavigateCommand}" CommandParameter="History">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Tarix (History)" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Background="#1A1A1A" Padding="15">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#AAA" FontSize="11" TextWrapping="Wrap"/>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Margin="30">
            
            <!-- Content Area -->
            <ContentControl Margin="20" Content="{Binding CurrentViewModel}">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
                        <views:DashboardView />
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewModels:SendingViewModel}">
                        <views:SendingView />
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewModels:ContactsViewModel}">
                        <views:ContactsView />
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewModels:TemplatesViewModel}">
                        <views:TemplatesView />
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewModels:BlacklistViewModel}">
                        <views:BlacklistView />
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewModels:BackupViewModel}">
                        <views:BackupView />
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewModels:HistoryViewModel}">
                        <views:HistoryView />
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>

        </Grid>
    </Grid>
</Window>
