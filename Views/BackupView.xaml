<UserControl x:Class="SmsGatewayApp.Views.BackupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Xavfsizlik va Zaxira (Backup)" Style="{StaticResource HeaderLabel}"/>

        <Border Grid.Row="1" Style="{StaticResource CardBorder}" HorizontalAlignment="Left" VerticalAlignment="Top" Padding="30">
            <StackPanel Width="400">
                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock Text="Ma'lumotlar Bazasi Zaxirasi" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Tizimdagi barcha guruhlar, kontaktlar, shablonlar va yuborish tarixini xavfsiz joyga .zip shaklida saqlab oling." 
                           Foreground="{StaticResource TextDimBrush}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,30"/>
                
                <Button Content="Zaxira Yaratish (Export)" Style="{StaticResource ModernButton}" Height="50" FontSize="16" Command="{Binding BackupCommand}" Margin="0,0,0,15"/>
                <Button Content="Zaxiradan Tiklash (Import)" Background="#1AFFFFFF" BorderThickness="1" BorderBrush="#33FFFFFF" Height="50" FontSize="16" Command="{Binding RestoreCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
