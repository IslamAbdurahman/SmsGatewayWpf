<Window x:Class="SmsGatewayApp.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SMS History" Height="500" Width="750"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}">
    <Border Padding="30">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Margin="0,0,0,30">
                <TextBlock Text="SMS HISTORY" FontSize="28" FontWeight="ExtraBold" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock x:Name="ContactInfo" FontSize="16" Foreground="{StaticResource TextDimBrush}" Margin="0,5,0,0"/>
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="0">
                <DataGrid x:Name="HistoryGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          Background="Transparent" BorderThickness="0" GridLinesVisibility="None"
                          RowBackground="Transparent" Foreground="{StaticResource TextBrush}"
                          RowHeight="40" FontSize="14">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="15,10"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#2AFFFFFF"/>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1AFFFFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding SentAt, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" Width="160"/>
                        <DataGridTextColumn Header="Message" Binding="{Binding MessageBody}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="Sent">
                                            <Setter Property="Foreground" Value="#10B981"/>
                                        </Trigger>
                                        <Trigger Property="Text" Value="Failed">
                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderThickness="0" Foreground="Red" Click="Delete_Click" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Button Grid.Row="2" Content="Close" Width="120" HorizontalAlignment="Right" Margin="0,30,0,0" 
                    Style="{StaticResource ModernButton}" Click="Close_Click"/>
        </Grid>
    </Border>
</Window>
